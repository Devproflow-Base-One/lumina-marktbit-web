    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "reactflow": "^11.11.4",
    "recharts": "^2.8.0",
    "socket.io-client": "^4.8.3",
    "source-map-js": "^1.2.1",
